<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<!-- Changed the window root be resizeable with default sizes -->
<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" width="900" height="700" minWidth="300" minHeight="150">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene width="900" height="700">
      <stylesheets>
        <URL value="@LightTheme.css" />
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox spacing="5.0" prefWidth="${scene.width}" prefHeight="${scene.height}">
        <padding>
          <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>

        <!-- Scrollable text area tt fills available vertical and horizontal space -->
        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" prefHeight="10000">
          <TextArea fx:id="helpMessage"
                    editable="false"
                    wrapText="true"
                    VBox.vgrow="ALWAYS"
                    prefHeight="10000"/>
        </ScrollPane>

        <!-- Button row at the bottom -->
        <HBox alignment="CENTER_RIGHT">
          <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL" />
        </HBox>

      </VBox>

    </Scene>
  </scene>
</fx:root>
