<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.FlowPane?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets left="7" right="7"/>
    </padding>
    <GridPane HBox.hgrow="ALWAYS" vgap="2" hgap="8">
        <padding>
            <Insets left="3" right="3" bottom="4" top="4" />
        </padding>
        <columnConstraints>
            <ColumnConstraints minWidth="20" prefWidth="20" maxWidth="20" hgrow="NEVER" />
            <ColumnConstraints minWidth="110" prefWidth="110" maxWidth="110" hgrow="NEVER" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="150" prefWidth="150" maxWidth="150" hgrow="NEVER" />
        </columnConstraints>

        <Label fx:id="id" GridPane.rowIndex="0" GridPane.columnIndex="0"
               GridPane.rowSpan="2" styleClass="cell-small-label" />
        <Label fx:id="name"
               GridPane.rowIndex="0"
               GridPane.columnIndex="1"
               styleClass="tag-combo-label" />
        <StackPane GridPane.rowIndex="0" GridPane.columnIndex="3"
                   prefWidth="150" maxWidth="150" >
            <FlowPane fx:id="tagsCardTagCombo"
                      orientation="HORIZONTAL"
                      alignment="CENTER_LEFT"/>
        </StackPane>
    </GridPane>
</HBox>
